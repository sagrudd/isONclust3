{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sagrudd/isONclust3/schemas/output-contract-register.schema.json",
  "title": "isONclust3 final_clusters.tsv output-contract register",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "manifest_kind",
    "manifest_id",
    "project",
    "contract",
    "entries"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "../../schemas/output-contract-register.schema.json"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "manifest_kind": {
      "type": "string",
      "const": "isonclust3-output-contract-register"
    },
    "manifest_id": {
      "type": "string",
      "const": "isonclust3-final-clusters-contract-v1"
    },
    "project": {
      "type": "string",
      "const": "isONclust3"
    },
    "contract": {
      "type": "string",
      "const": "final_clusters.tsv"
    },
    "entries": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/entry"
      }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "mode",
        "benchmark_tier",
        "run_path",
        "fastq_path",
        "fastq_sha256",
        "fastq_bytes",
        "sha256",
        "bytes",
        "status",
        "consumer"
      ],
      "properties": {
        "entry_id": {
          "type": "string",
          "minLength": 1,
          "enum": [
            "isonclust3-tiny-ont-final-clusters",
            "isonclust3-gff-tiny-ont-final-clusters",
            "isonclust3-tiny-pacbio-final-clusters",
            "isonclust3-gff-tiny-pacbio-final-clusters"
          ]
        },
        "mode": {
          "type": "string",
          "enum": [
            "ont",
            "pacbio"
          ]
        },
        "benchmark_tier": {
          "type": "string",
          "const": "toy"
        },
        "run_path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+"
        },
        "fastq_path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+"
        },
        "fastq_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "fastq_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "bytes": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "const": "resolved"
        },
        "consumer": {
          "type": "string",
          "const": "newONform"
        }
      }
    }
  }
}
