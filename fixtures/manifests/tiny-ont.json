{
  "schema_version": 1,
  "manifest_kind": "isonclust3-benchmark-fixture",
  "manifest_id": "isonclust3-tiny-ont",
  "project": "isONclust3",
  "benchmark_tier": "toy",
  "mode": "ont",
  "seeding": "minimizer",
  "source": {
    "description": "Project-authored tiny ONT-like FASTQ for output-contract smoke tests.",
